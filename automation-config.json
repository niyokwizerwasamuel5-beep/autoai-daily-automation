{\n  \"name\": \"AutoAI Daily - Full Automation\",\n  \"description\": \"Complete YouTube automation for AI tutorials\",\n  \"version\": \"1.0.0\",\n  \"scenario\": {\n    \"triggers\": [\n      {\n        \"type\": \"schedule\",\n        \"settings\": {\n          \"hour\": 8,\n          \"minute\": 0,\n          \"days\": [\"monday\",\"tuesday\",\"wednesday\",\"thursday\",\"friday\",\"saturday\",\"sunday\"]\n        }\n      }\n    ],\n    \"routes\": {\n      \"news\": {\n        \"modules\": [\n          {\n            \"id\": \"rss_1\",\n            \"app\": \"rss\",\n            \"action\": \"watchFeed\",\n            \"settings\": {\n              \"feedUrl\": \"https://techcrunch.com/tag/artificial-intelligence/feed\",\n              \"limit\": 3\n            }\n          },\n          {\n            \"id\": \"openai_1\",\n            \"app\": \"openai\",\n            \"action\": \"createCompletion\",\n            \"settings\": {\n              \"model\": \"gpt-4-turbo-preview\",\n              \"prompt\": \"Create a 3-minute YouTube script from these news items: {{rss_1.items}}. Format: [HOOK] [STORY1] [STORY2] [STORY3] [OUTRO]\",\n              \"temperature\": 0.7,\n              \"maxTokens\": 800\n            }\n          },\n          {\n            \"id\": \"elevenlabs_1\",\n            \"app\": \"elevenlabs\",\n            \"action\": \"generateAudio\",\n            \"settings\": {\n              \"voiceId\": \"YOUR_VOICE_ID_HERE\",\n              \"text\": \"{{openai_1.choices[0].text}}\",\n              \"stability\": 0.75,\n              \"similarity\": 0.85\n            }\n          },\n          {\n            \"id\": \"pictory_1\",\n            \"app\": \"pictory\",\n            \"action\": \"createVideo\",\n            \"settings\": {\n              \"script\": \"{{openai_1.choices[0].text}}\",\n              \"audioUrl\": \"{{elevenlabs_1.audioUrl}}\",\n              \"template\": \"tech-news\",\n              \"stockFootage\": \"technology,ai,robots,future\"\n            }\n          },\n          {\n            \"id\": \"youtube_1\",\n            \"app\": \"youtube\",\n            \"action\": \"uploadVideo\",\n            \"settings\": {\n              \"channelId\": \"UCrdp9Tbtvwhy_vLvpwusrYA\",\n              \"title\": \"AI News: {{rss_1.items[0].title}} - {{formatDate now 'MMM D, YYYY'}}\",\n              \"description\": \"Today's top AI stories:\\n\\n{{#each rss_1.items}}\\n• {{this.title}}: {{this.link}}\\n{{/each}}\\n\\n🚀 Try these AI tools:\\n→ ChatGPT: https://openai.com/?ref=autoai\\n→ Midjourney: https://midjourney.com/?ref=autoai\\n→ Pictory: https://pictory.ai/?ref=autoai\\n→ ElevenLabs: https://elevenlabs.io/?ref=autoai\\n\\n#AINews #ArtificialIntelligence #TechNews\",\n              \"tags\": [\"AI\", \"news\", \"technology\", \"artificial intelligence\", \"machine learning\"],\n              \"privacyStatus\": \"public\",\n              \"schedule\": \"now\"\n            }\n          }\n        ]\n      },\n      \"tutorial\": {\n        \"modules\": [\n          {\n            \"id\": \"sheets_1\",\n            \"app\": \"googleSheets\",\n            \"action\": \"getNextRow\",\n            \"settings\": {\n              \"spreadsheetId\": \"YOUR_SPREADSHEET_ID_HERE\",\n              \"sheetName\": \"Tools\",\n              \"columns\": [\"Tool Name\", \"Category\", \"Features\", \"Affiliate Link\"]\n            }\n          },\n          {\n            \"id\": \"openai_2\",\n            \"app\": \"openai\",\n            \"action\": \"createCompletion\",\n            \"settings\": {\n              \"model\": \"gpt-4-turbo-preview\",\n              \"prompt\": \"Write a 5-minute tutorial for {{sheets_1.Tool Name}}. Features: {{sheets_1.Features}}. Include: problem it solves, step-by-step setup, 3 use cases, 1 pro tip, call to action.\",\n              \"temperature\": 0.5,\n              \"maxTokens\": 1200\n            }\n          }\n        ]\n      }\n    }\n  }\n}